<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <propertyType 
               name="T" 
               extends="SObject" 
               label="Select a sObject" 
               description="Select a sObject" 
            />
            
            <property 
                name="records" 
                type="{T[]}" 
                label="contact value List" 
            />

            <property 
                name="updatedRecords" 
                type="{T[]}" 
                label="Updated Contact Records" 
                role="outputOnly" 
                description="Return modified Contact records back to Flow" />

        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>