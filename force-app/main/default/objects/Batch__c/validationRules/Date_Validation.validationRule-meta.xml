<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Date_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>End_Date__c  -  Start_Date__c      &lt;   (Program__r.Duration__c * 365)</errorConditionFormula>
    <errorMessage>Batch Dates should not be less than program duration</errorMessage>
</ValidationRule>
