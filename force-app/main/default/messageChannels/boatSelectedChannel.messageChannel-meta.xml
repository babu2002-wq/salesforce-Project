    <isExposed>true</isExposed>
    <lightningMessageFields>
        <description>Id of the selected boat</description>
        <fieldName>boatId</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Name of the selected boat</description>
        <fieldName>boatName</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Price of the selected boat</description>
        <fieldName>boatPrice</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Type of the selected boat</description>
        <fieldName>boatType</fieldName>
    </lightningMessageFields>
